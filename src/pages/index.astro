---
import '../styles/global.css';

const projects = [
  { name: 'Wallppy', desc: 'Wallpaper manager for Linux desktop with multi-source browsing', tech: ['Python', 'PyQt5', 'Linux'], repo: 'wallppy' },
  { name: 'EcoTraveler', desc: 'React Native app for sustainable tourism attractions', tech: ['React Native', 'Expo', 'JSX'], repo: 'ecotraveler' },
  { name: 'AboNews', desc: 'Laravel news portal for Ado artist fans with CRUD and auth', tech: ['Laravel', 'Tailwind', 'MySQL'], repo: 'abonews' },
];

const skills = ['React', 'Node.js', 'MySQL', 'Docker', 'Python', 'C', 'Linux', 'Web'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dev Portfolio</title>
  </head>
  <body>
    <main>
      <header class="name">
        <h1>Pedro Henrique</h1>
        <p class="tagline">Full-stack developer</p>
      </header>

      <section class="about">
        <h2>About</h2>
        <p>Building scalable systems. Focused on performance and clean architecture.</p>
      </section>

      <section class="skills">
        <h2>Skills</h2>
        <div class="skill-list">
          {skills.map(skill => <span class="skill-tag">{skill}</span>)}
        </div>
      </section>

      <section class="projects">
        <h2>Projects</h2>
        <div class="project-grid">
          {projects.map(project => (
            <a href={`https://github.com/stingy-namake/${project.repo}`} target="_blank" class="project-card">
              <h3>{project.name}</h3>
              <p>{project.desc}</p>
              <div class="tech-stack">
                {project.tech.map(t => <span class="tech-tag">{t}</span>)}
              </div>
            </a>
          ))}
        </div>
      </section>

      <footer>
        <a href="https://github.com/stingy-namake" target="_blank">GitHub</a>
        <a href="https://linkedin.com/in/pedro-henrique-barboza" target="_blank">LinkedIn</a>
        <a href="mailto:email.escolar174@gmail.com">Email</a>
      </footer>
    </main>
    <script is:inline>
      document.querySelectorAll('.project-card').forEach(card => {
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mouse-x', `${e.clientX - r.left}px`);
          card.style.setProperty('--mouse-y', `${e.clientY - r.top}px`);
        });
      });
    </script>
  </body>
</html>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
  }
  header {
    margin-bottom: 5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  header::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 50%;
    width: 60px;
    height: 1px;
    background: rgba(255,255,255,0.3);
  }
  h1 {
    font-size: 3.5rem;
    font-weight: 200;
    letter-spacing: -0.03em;
    margin: 0;
    line-height: 1.1;
    background: linear-gradient(180deg, #fff 0%, #999 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  h2 {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }
  .name {
    text-align: center;
  }
  .tagline {
    color: var(--text-muted);
    margin-top: 0.75rem;
    font-size: 1.1rem;
    font-weight: 300;
    letter-spacing: 0.02em;
  }
  section {
    margin-bottom: 5rem;
  }
  .about p {
    color: #aaa;
    /* max-width: 560px; */
    /* margin: 0 auto; */
    /* text-align: justify; */
    line-height: 1.8;
    font-size: 1.05rem;
  }
  .skill-list {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .skill-tag {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.45rem 1rem;
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--text-muted);
    border-radius: 100px;
    transition: all 0.2s ease;
    letter-spacing: 0.02em;
  }
  .skill-tag:hover {
    border-color: var(--border-hover);
    color: #ddd;
    background: var(--bg-card-hover);
    transform: translateY(-1px);
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1.75rem;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.04), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .project-card:hover::before {
    opacity: 1;
  }
  .project-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .project-card h3 {
    font-weight: 500;
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .project-card p {
    color: #666;
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tech-tag {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.5rem;
    background: rgba(255,255,255,0.03);
    border-radius: 4px;
  }
  footer {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }
  footer a {
    color: var(--text-dim);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
    position: relative;
  }
  footer a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: #fff;
    transition: width 0.2s;
  }
  footer a:hover {
    color: #ccc;
  }
  footer a:hover::after {
    width: 100%;
  }
</style>
