---
export const prerender = false;
import '../styles/global.css';

const projects = [
  { name: 'Wallppy', desc: 'Wallpaper manager for Linux desktop with multi-source browsing', tech: ['Python', 'PyQt5', 'Linux'] },
  { name: 'EcoTraveler', desc: 'React Native app for sustainable tourism attractions', tech: ['React Native', 'Expo', 'JSX'] },
  { name: 'AboNews', desc: 'Laravel news portal for Ado artist fans with CRUD and auth', tech: ['Laravel', 'Tailwind', 'MySQL'] },
];

const skills = ['React', 'Node.js', 'MySQL', 'Docker', 'Python', 'C', 'Linux', 'Web'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dev Portfolio</title>
  </head>
  <body>
    <main>
      <header>
        <h1>Pedro Henrique</h1>
        <p class="tagline">Full-stack developer</p>
      </header>

      <section class="about">
        <h2>About</h2>
        <p>Building scalable systems. Focused on performance and clean architecture.</p>
      </section>

      <section class="skills">
        <h2>Skills</h2>
        <div class="skill-list">
          {skills.map(skill => <span class="skill-tag">{skill}</span>)}
        </div>
      </section>

      <section class="projects">
        <h2>Projects</h2>
        <div class="project-grid">
          {projects.map(project => (
            <article class="project-card">
              <h3>{project.name}</h3>
              <p>{project.desc}</p>
              <div class="tech-stack">
                {project.tech.map(t => <span class="tech-tag">{t}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <footer>
        <a href="https://github.com/stingy-namake" target="_blank">GitHub</a>
        <a href="https://linkedin.com/in/pedro-henrique-barboza" target="_blank">LinkedIn</a>
        <a href="mailto:email.escolar174@gmail.com">Email</a>
      </footer>
    </main>
  </body>
</html>

<style>
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  header {
    margin-bottom: 4rem;
    border-bottom: 1px solid #2a2a2a;
    padding-bottom: 2rem;
  }
  h1 {
    font-size: 3rem;
    font-weight: 300;
    margin: 0;
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.8)
  }
  h2 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #666;
    margin-bottom: 1.5rem;
  }
  .tagline {
    color: #888;
    margin-top: 0.5rem;
  }
  section {
    margin-bottom: 4rem;
  }
  .about p {
    color: #aaa;
    max-width: 600px;
    line-height: 1.8;
  }
  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .skill-tag {
    background: #111;
    border: 1px solid #222;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    color: #999;
    transition: border-color 0.2s, color 0.2s;
  }
  .skill-tag:hover {
    border-color: #444;
    color: #ccc;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .project-card {
    background: #0d0d0d;
    border: 1px solid #1a1a1a;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .project-card:hover {
    border-color: #333;
  }
  .project-card h3 {
    font-weight: 400;
    margin: 0 0 0.5rem;
  }
  .project-card p {
    color: #777;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tech-tag {
    font-size: 0.7rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  footer {
    display: flex;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #1a1a1a;
  }
  footer a {
    color: #555;
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  footer a:hover {
    color: #999;
  }
</style>
